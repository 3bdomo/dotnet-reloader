<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <AssemblyName>dotnet-reloader</AssemblyName>
    <RootNamespace>DotnetReloader</RootNamespace>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>dotnet-reloader</ToolCommandName>
    <PackageId>DotnetReloader</PackageId>
    <Version>1.0.0</Version>
    <Description>Auto-rebuild and run .NET projects on file changes</Description>
  </PropertyGroup>

</Project>
